{
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "social-image-gen",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        200,
        300
      ],
      "webhookId": "b1c8f1a1-1234-abcd-8f55-12a3b4c5d6e7"
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "set-prompt",
      "name": "Set Prompt",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [
        400,
        300
      ]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendPhoto",
        "chatId": "={{ $('Webhook').item.json.body.message.chat.id }}",
        "binaryData": true,
        "binaryPropertyName": "data",
        "additionalFields": {}
      },
      "id": "telegram-output",
      "name": "Send a photo message",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [
        1200,
        300
      ],
      "credentials": {
        "telegramApi": {
          "id": "your-telegram-credential-id",
          "name": "IRO Picasso"
        }
      }
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Set Prompt",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Convert FLUX Base64 to Image1": {
      "main": [
        [
          {
            "node": "Send a photo message",
            "type": "main",
            "index": 0
          },
          {
             "node": "Google Drive",
             "type": "main",
             "index": 0
          }
        ]
      ]
    }
  }
}
